datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Organization {
  id                Int       @id @default(autoincrement())
  name              String
  registrationNumber String?
  industry          String?
  size              String?
  country           String?
  region            String?
  address           String?
  email             String?
  phone             String?
  logoUrl           String?
  currency          String    @default("KES")
  payrollFrequency  String    @default("MONTHLY")
  paymentMethod     String    @default("BANK") // BANK, MPESA, BOTH
  timezone          String    @default("Africa/Nairobi")
  workingDays       String    @default("Monday-Friday")
  branches          Branch[]
  users             User[]
  invitations       Invitation[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model User {
  id                Int      @id @default(autoincrement())
  email             String   @unique
  password          String
  name              String
  role              String   // OWNER, MANAGER, HR, ACCOUNTANT, PAYROLL_OFFICER, EMPLOYEE
  status            String   @default("PENDING_VERIFICATION") // PENDING_VERIFICATION, ACTIVE, LOCKED
  failedLoginAttempts Int    @default(0)
  lockoutUntil      DateTime?
  organizationId    Int?
  organization      Organization? @relation(fields: [organizationId], references: [id])
  branchId          Int?
  branch            Branch?  @relation(fields: [branchId], references: [id])
  twoFactorEnabled  Boolean  @default(false)
  lastLoginIp       String?
  lastLoginDevice   String?
  otps              OTP[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model OTP {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  code      String
  type      String   // EMAIL_VERIFICATION, PASSWORD_RESET, 2FA
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Invitation {
  id             Int          @id @default(autoincrement())
  code           String       @unique
  email          String
  role           String
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  status         String       @default("PENDING") // PENDING, ACCEPTED, EXPIRED
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
}

model Branch {
  id             Int          @id @default(autoincrement())
  name           String
  location       String?
  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  employees      Employee[]
  users          User[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Employee {
  id                Int                 @id @default(autoincrement())
  employeeNumber    String              @unique
  fullName          String
  nationalId        String              @unique
  phone             String
  email             String
  department        String
  position          String
  salary            Float               // Basic Salary
  employmentDate    String
  paymentMethod     String              // MPESA, AIRTEL, BANK, WALLET
  accountNumber     String              // Mobile number or Bank Account number
  taxPin            String
  status            String              @default("ACTIVE") // ACTIVE, SUSPENDED, ARCHIVED
  branchId          Int?
  branch            Branch?             @relation(fields: [branchId], references: [id])
  passportPhoto     String?
  nssfNumber        String?
  nhifNumber        String?
  housingLevy       Boolean             @default(true)
  employmentType    String              @default("FULL_TIME") // FULL_TIME, CONTRACT, CASUAL
  bankAccount       String?
  mpesaNumber       String?
  emergencyContacts String?
  documents         Document[]
  leaveRecords      LeaveRecord[]
  attendanceRecords AttendanceRecord[]
  performanceReviews PerformanceReview[]
  advances          SalaryAdvance[]
  payrollRuns       PayrollRun[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model Document {
  id         Int      @id @default(autoincrement())
  name       String
  url        String
  category   String   // CONTRACT, ID, TAX, OTHER
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model LeaveRecord {
  id         Int      @id @default(autoincrement())
  type       String   // ANNUAL, SICK, MATERNITY, PATERNITY, UNPAID
  startDate  String
  endDate    String
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AttendanceRecord {
  id         Int      @id @default(autoincrement())
  date       String   // YYYY-MM-DD
  checkIn    String?  // HH:MM
  checkOut   String?  // HH:MM
  status     String   @default("PRESENT") // PRESENT, ABSENT, LATE, HALFDAY
  overtime   Float    @default(0) // Hours
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PerformanceReview {
  id          Int      @id @default(autoincrement())
  reviewDate  String   // YYYY-MM-DD
  rating      Int      // 1 to 5
  notes       String?
  employeeId  Int
  employee    Employee @relation(fields: [employeeId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SalaryAdvance {
  id              Int      @id @default(autoincrement())
  employeeId      Int
  employee        Employee @relation(fields: [employeeId], references: [id])
  amount          Float
  requestDate     String
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED, PAID
  repaymentPeriod Int      @default(1)         // Number of months to pay back
  deductedAmount  Float    @default(0)         // How much has already been deducted from payrolls
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PayrollRun {
  id               Int       @id @default(autoincrement())
  month            String    // Format: YYYY-MM (e.g., 2026-06)
  employeeId       Int
  employee         Employee  @relation(fields: [employeeId], references: [id])
  basicSalary      Float
  overtimeHours    Float     @default(0)
  overtimeRate     Float     @default(0) // Rate per hour
  bonusAmount      Float     @default(0)
  deductions       Float     @default(0) // General deductions (tax, pension, insurance, etc.)
  advanceDeduction Float     @default(0) // Automatic salary advance deduction
  penalties        Float     @default(0)
  netSalary        Float
  status           String    @default("DRAFT") // DRAFT, HR_APPROVED, FINANCE_APPROVED, PAID
  paymentDate      String?
  paymentReference String?
  branchId         Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Transaction {
  id            Int      @id @default(autoincrement())
  payrollPeriod String   // Format: YYYY-MM
  totalAmount   Float
  paymentMethod String   // MPESA, AIRTEL, BANK, ALL
  status        String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  initiatorId   Int      // User ID who triggered the payment
  timestamp     DateTime @default(now())
  referenceCode String   @unique
}

model AuditLog {
  id            Int      @id @default(autoincrement())
  userId        Int?
  userName      String?
  action        String
  details       String?
  ipAddress     String?
  deviceDetails String?
  timestamp     DateTime @default(now())
}

model Wallet {
  id           Int                 @id @default(autoincrement())
  type         String              // MPESA, BANK
  balance      Float               @default(0)
  floatBalance Float               @default(0)
  currency     String              @default("KES")
  transactions WalletTransaction[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model WalletTransaction {
  id        Int      @id @default(autoincrement())
  walletId  Int
  wallet    Wallet   @relation(fields: [walletId], references: [id])
  amount    Float
  type      String   // DEPOSIT, WITHDRAWAL, PAYOUT
  reference String
  status    String   @default("COMPLETED") // COMPLETED, PENDING, FAILED
  timestamp DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int?     // Target user or null for all users
  title     String
  message   String
  category  String   // PAYROLL, EMPLOYEE, FINANCE, COMPLIANCE, SYSTEM
  status    String   @default("UNREAD") // UNREAD, READ
  createdAt DateTime @default(now())
}
